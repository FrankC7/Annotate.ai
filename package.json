{
  "name": "annotate-ai",
  "displayName": "Annotate.ai",
  "description": "AI-powered code annotation and authorship analysis.",
  "version": "1.0.0",
  "type": "module",
  "publisher": "Annotate-ai",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "annotate-ai-explorer",
          "title": "Annotate.ai",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "annotate-ai-explorer": [
        {
          "id": "annotate-ai.fileHistoryView",
          "name": "File History",
          "type": "webview",
          "icon": "$(history)"
        }
      ]
    },
    "commands": [
      {
        "command": "annotate-ai.annotateSelection",
        "title": "Annotate: Add AI Comment",
        "icon": "$(edit)"
      },
      {
        "command": "annotate-ai.annotateFile",
        "title": "Annotate: Annotate Entire File",
        "icon": "$(comment)"
      },
      {
        "command": "annotate-ai.toggleHoverExplainer",
        "title": "Annotate: Toggle Hover Explainer",
        "icon": "$(info)"
      },
      {
        "command": "annotate-ai.showDiff",
        "title": "Annotate: Show Changes",
        "icon": "$(eye)"
      },
      {
        "command": "annotate-ai.generateReadme",
        "title": "Annotate: Generate README",
        "icon": "$(book)"
      },
      {
        "command": "annotate-ai.changeApiKeys",
        "title": "Annotate: Change API Keys",
        "category": "Annotate.ai"
      },
      {
        "command": "annotate-ai.setAstraCredentials",
        "title": "Annotate: Set Astra DB Credentials",
        "category": "Annotate.ai"
      },
      {
        "command": "annotate-ai.indexWorkspace",
        "title": "Annotate: Index Workspace for RAG",
        "category": "Annotate.ai",
        "icon": "$(database)"
      },
      {
        "command": "annotate-ai.indexCommits",
        "title": "Annotate: Index Commit History for RAG",
        "category": "Annotate.ai",
        "icon": "$(git-commit)"
      },
      {
        "command": "annotate-ai.generateCommitMessage",
        "title": "Annotate: Generate Commit Message",
        "icon": "$(git-commit)"
      },
      {
        "command": "annotate-ai.generatePRDescription",
        "title": "Annotate: Generate PR Description",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "annotate-ai.toggleGitBlame",
        "title": "Annotate: Toggle Git Blame",
        "icon": "$(organization)"
      },
      {
        "command": "annotate-ai.copyCommitHash",
        "title": "Copy Commit Hash",
        "category": "Annotate.ai"
      },
      {
        "command": "annotate-ai.showFileAtCommit",
        "title": "Annotate: Show File At Commit",
        "category": "Annotate.ai"
      },
      {
        "command": "annotate-ai.aiCodeReview",
        "title": "Annotate: AI Code Review",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "annotate-ai.annotateSelection",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.annotateFile",
          "group": "navigation@2",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.showDiff",
          "group": "navigation@3",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.generateReadme",
          "group": "navigation@4",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.toggleHoverExplainer",
          "group": "navigation@5",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.toggleGitBlame",
          "group": "navigation@6",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.changeApiKeys",
          "group": "navigation@9",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.setAstraCredentials",
          "group": "navigation@10",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.indexWorkspace",
          "group": "navigation@11",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.indexCommits",
          "group": "navigation@12",
          "when": "editorTextFocus"
        }
      ],
      "editor/title": [
        {
          "command": "annotate-ai.annotateSelection",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.annotateFile",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.showDiff",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.generateReadme",
          "group": "navigation@1",
          "when": "editorTextFocus"
        }
      ],
      "scm/title": [
        {
          "command": "annotate-ai.generateCommitMessage",
          "group": "navigation@1",
          "when": "scmProvider == git"
        },
        {
          "command": "annotate-ai.generatePRDescription",
          "group": "navigation@2",
          "when": "scmProvider == git"
        },
        {
          "command": "annotate-ai.aiCodeReview",
          "group": "navigation@3",
          "when": "scmProvider == git"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FrankC7/Annotate.ai"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@datastax/astra-db-ts": "^2.2.1",
    "@octokit/rest": "^22.0.1",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.6",
    "cross-keychain": "^1.1.0",
    "diff": "^8.0.3",
    "groq-sdk": "^1.1.1"
  }
}
