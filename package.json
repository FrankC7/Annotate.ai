{
  "name": "annotate-ai",
  "displayName": "Annotate.ai",
  "description": "",
  "version": "0.0.1",
  "publisher": "Annotate-ai",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "annotate-ai.addAndHighlight",
        "title": "Annotate: Add Text",
        "icon": "$(add)"
      },
      {
        "command": "annotate-ai.showDiff",
        "title": "Annotate: Show Changes",
        "icon": "$(diff-inserted)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "annotate-ai.addAndHighlight",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.showDiff",
          "group": "navigation@2",
          "when": "editorTextFocus"
        }
      ],
      "editor/title": [
        {
          "command": "annotate-ai.addAndHighlight",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "annotate-ai.showDiff",
          "group": "navigation@2",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/FrankC7/Annotate.ai"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
